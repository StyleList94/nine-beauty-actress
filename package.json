{
  "name": "@stylelist94/nine-beauty-actress",
  "version": "2.2.0",
  "description": "Lovely G219",
  "keywords": [
    "UI Kit",
    "component library",
    "react",
    "typescript"
  ],
  "homepage": "https://nine.styleli.sh",
  "bugs": {
    "url": "https://github.com/StyleList94/nine-beauty-actress/issues"
  },
  "license": "MIT",
  "author": "StyleList94",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/StyleList94/nine-beauty-actress.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "module": "./dist/main.js",
  "types": "./dist/main.d.ts",
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "import": "./dist/main.js"
    },
    "./styles": {
      "types": "./dist/core/styles.d.ts",
      "import": "./dist/styles.js"
    },
    "./tokens": {
      "types": "./dist/core/tokens.d.ts",
      "import": "./dist/tokens.js"
    },
    "./style.css": "./dist/style.css",
    "./tailwind-theme.css": "./dist/tailwind-theme.css"
  },
  "scripts": {
    "dev": "storybook dev -p 6006",
    "build": "tsc --noEmit && vite build && node build/generate-tailwind-theme.js",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "preview": "vite preview",
    "build-storybook": "storybook build",
    "prepare": "husky",
    "test": "vitest run --browser.headless",
    "test:unit": "vitest run --project unit",
    "test:browser": "vitest run --project browser --browser.headless",
    "test:coverage": "vitest run --coverage --browser.headless",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@daypicker/react": "^10.0.1",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
